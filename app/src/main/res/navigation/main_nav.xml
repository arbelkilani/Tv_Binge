<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main_nav"
    app:startDestination="@id/navigation_splash">

    <fragment
        android:id="@+id/navigation_splash"
        android:name="com.arbelkilani.binge.tv.presentation.splash.presentation.SplashFragment"
        android:label="fragment_splash"
        tools:layout="@layout/fragment_splash" >
        <action
            android:id="@+id/action_navigation_splash_to_navigation_walkthrough"
            app:destination="@id/navigation_walkthrough"
            app:popUpTo="@id/main_nav"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_navigation_splash_to_navigation_dashboard"
            app:destination="@id/navigation_dashboard"
            app:popUpTo="@id/main_nav"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/navigation_walkthrough"
        android:name="com.arbelkilani.binge.tv.presentation.walkthrough.presentation.WalkthroughFragment"
        android:label="fragment_walkthrough"
        tools:layout="@layout/fragment_walkthrough" />

    <fragment
        android:id="@+id/navigation_dashboard"
        android:name="com.arbelkilani.binge.tv.presentation.ui.dashboard.DashboardFragment"
        android:label="fragment_dashboard"
        tools:layout="@layout/fragment_dashboard" />

</navigation>